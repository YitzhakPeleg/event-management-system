<?xml version="1.0" encoding="utf-8"?>
<!-- Admin QR scanner screen.
     The actual camera viewfinder is launched as a separate Activity by
     ZXing IntentIntegrator — this screen just shows the result. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#2C3E50"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="← Back"
            android:textSize="12sp"
            android:backgroundTint="#7F8C8D"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Scan QR Code"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Center panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <!-- QR code icon (visual hint) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#x1F4F7;"
            android:textSize="64sp"
            android:layout_marginBottom="16dp" />

        <!-- Loading indicator while validating token -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

        <!-- Result text — green for valid, red for invalid (set in code) -->
        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:visibility="gone"
            android:layout_marginBottom="24dp" />

        <!-- "Start Scan" button — opens the ZXing camera scanner -->
        <Button
            android:id="@+id/btnStartScan"
            android:layout_width="200dp"
            android:layout_height="52dp"
            android:text="Open Camera Scanner"
            android:backgroundTint="#2980B9"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <!-- "Scan Again" button — shown after each scan -->
        <Button
            android:id="@+id/btnScanAgain"
            android:layout_width="200dp"
            android:layout_height="52dp"
            android:text="Scan Again"
            android:backgroundTint="#27ae60"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
